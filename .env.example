# Copy this file to .env and fill in your keys.
# `thesis setup` will do this for you interactively.

# Which LLM provider to use: "anthropic" (default) or "openrouter".
THESIS_PROVIDER=anthropic

# --- Anthropic (THESIS_PROVIDER=anthropic) -----------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenRouter (THESIS_PROVIDER=openrouter) ---------------------------------
# Get a key at https://openrouter.ai/keys
# Browse models at https://openrouter.ai/models
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://github.com/your-org/thesis-agent   # optional, for attribution
# OPENROUTER_SITE_NAME=thesis-agent                              # optional

# --- OpenRouter fallback routing ---------------------------------------------
# When the primary model is unavailable (outage, rate limit, content filter),
# OpenRouter falls through this comma-separated chain. Empty string disables
# fallback entirely. Default: google/gemma-4-31b-it (free-tier capable).
# THESIS_OPENROUTER_FALLBACK=google/gemma-4-31b-it

# --- Model overrides (both providers) ----------------------------------------
# Anthropic-format IDs (e.g. "anthropic:claude-sonnet-4-6") when provider is anthropic.
# OpenRouter-format IDs when provider is openrouter.
#
# OpenRouter defaults (optimised for cost vs quality):
#   drafter    = z-ai/glm-5.1              (~$1/M input, 200K context)
#   curator    = z-ai/glm-5.1              (same; wiki-building is quality-critical)
#   researcher = google/gemma-4-31b-it     (~$0.13/M input, 256K context)
#
# THESIS_MODEL_DRAFTER=
# THESIS_MODEL_CURATOR=
# THESIS_MODEL_RESEARCHER=
